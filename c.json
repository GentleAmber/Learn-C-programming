{
	"for loop": {
		"prefix": "fori",
		"body": [
			"for (int ${1:i} = ${2:0}; ${1} < ${3:n}; ${1}++) {",
			"\t$0",
			"}"
		],
		"description": "for loop's template"
	},

	"boilerplate": {
		"prefix": "boi",
		"body": [
			"#include <stdio.h>",
			"#include <stdlib.h>",
			"",
			"int main(void) {",
			"\t$0",
			"\treturn 0;",
			"}"
		],
		"description": "boilerplate for beginners, including <stdio.h>, <stdlib.h>"
	},

	"while loop": {
		"prefix": "whi",
		"body": [
			"while(${1:condition}) {",
			"\t$0",
			"}"
		],
		"description": "while loop's template"
	},

	"print array (one-dimension)": {
		"prefix": "pri_arr1",
		"body": [
			"for (int i = 0; i < ${1:n}; i++) {",
			"\tprintf(\"%${2:d} \", ${3:a}[i]);",
			"}",
			"printf(\"\\n\");"
		],
		"description": "while loop's template"
	},

  "printf shortcut": {
    "prefix": "prif",
		"body": [
			"printf(\"$1\");"
		],
		"description": "shortcut for printf"
  }
}